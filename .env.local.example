# Frontend environment variables
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit it.

# From Supabase → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# From Supabase → Project Settings → API → anon (public) key
# This is the READ-ONLY key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here
